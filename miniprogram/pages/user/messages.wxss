.messages-page {
  padding-top: 24rpx;
}

.liked-me-shell {
  padding: 28rpx;
}

.liked-me-header {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.liked-me-heading {
  min-width: 0;
}

.liked-me-status {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(150, 59, 53, 0.1);
  color: #963b35;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.3;
}

.liked-me-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 26rpx;
}

.liked-card {
  position: relative;
  overflow: hidden;
  min-height: 276rpx;
  border-radius: 18rpx;
  background: #4b3f37;
}

.liked-card:active {
  transform: scale(0.985);
}

.liked-cover-wrap {
  position: relative;
  height: 276rpx;
}

.liked-cover {
  display: block;
  width: 100%;
  height: 276rpx;
  background: linear-gradient(135deg, #8b715f, #2f5364);
}

.liked-cover-placeholder {
  background: linear-gradient(135deg, #946850, #2f5364 52%, #9d4c61);
}

.tone-1 .liked-cover-placeholder {
  background: linear-gradient(135deg, #b18a42, #6b6572 54%, #2d5567);
}

.tone-2 .liked-cover-placeholder {
  background: linear-gradient(135deg, #687d75, #574f68 52%, #a35b49);
}

.tone-3 .liked-cover-placeholder {
  background: linear-gradient(135deg, #775b54, #315d66 48%, #c47a47);
}

.liked-card.locked .liked-cover {
  filter: blur(16rpx);
  transform: scale(1.08);
}

.liked-cover-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(23, 20, 18, 0.08), rgba(23, 20, 18, 0.84));
}

.liked-lock {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #963b35;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.liked-copy {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  left: 18rpx;
  min-width: 0;
}

.liked-hint,
.liked-name,
.liked-meta {
  display: block;
}

.liked-hint {
  display: inline-block;
  max-width: 100%;
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 245, 225, 0.88);
  color: #8b4a11;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.liked-name {
  overflow: hidden;
  color: #fffaf2;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.liked-meta {
  margin-top: 6rpx;
  overflow: hidden;
  color: rgba(255, 250, 242, 0.9);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.liked-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.liked-tag {
  max-width: 140rpx;
  padding: 6rpx 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fffaf2;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.liked-empty {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 28rpx 20rpx;
  border: 1rpx dashed rgba(150, 59, 53, 0.22);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.52);
}

.liked-empty-title {
  color: #402c22;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.liked-empty-note {
  color: #9b7b5d;
  font-size: 24rpx;
  line-height: 1.5;
}

.liked-unlock {
  width: 100%;
  margin-top: 26rpx;
  background: linear-gradient(135deg, #ff5f7e, #963b35);
  color: #fffaf2;
}

.conversation-shell {
  padding: 22rpx;
}

.conversation-card {
  position: relative;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  min-height: 132rpx;
}

.conversation-avatar {
  width: 92rpx;
  height: 92rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.conversation-copy {
  min-width: 0;
}

.conversation-title-row {
  align-items: flex-start;
}

.conversation-title,
.conversation-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conversation-title {
  max-width: 360rpx;
}

.conversation-time {
  flex: 0 0 auto;
  color: #9b7b5d;
  font-size: 21rpx;
  line-height: 1.4;
}

.conversation-tags {
  margin-top: 10rpx;
}

.unread-badge {
  position: absolute;
  top: 22rpx;
  right: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #963b35;
  color: #fff8ed;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 32rpx;
  text-align: center;
}

.empty-action {
  margin-top: 22rpx;
}
