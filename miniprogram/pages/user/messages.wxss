.messages-page {
  padding-top: 20rpx;
}

.relationship-shell {
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(56, 42, 29, 0.07);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.relationship-header {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.relationship-heading {
  min-width: 0;
}

.relationship-status {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.3;
}

.relationship-status.locked {
  background: rgba(150, 59, 53, 0.1);
  color: #963b35;
}

.relationship-status.open {
  background: rgba(62, 103, 88, 0.12);
  color: #3e6758;
}

.relationship-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.relationship-tab {
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 58rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  min-width: 0;
  min-height: 150rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 16rpx;
  background: rgba(244, 239, 231, 0.58);
  color: #745e4d;
}

.relationship-tab:active {
  transform: scale(0.99);
}

.relationship-tab.incoming.active {
  border-color: rgba(150, 59, 53, 0.42);
  background: rgba(150, 59, 53, 0.08);
  color: #963b35;
}

.relationship-tab.mutual.active {
  border-color: rgba(62, 103, 88, 0.42);
  background: rgba(62, 103, 88, 0.09);
  color: #3e6758;
}

.relationship-symbol {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.88);
  color: currentColor;
}

.relationship-symbol-heart .heart-shape {
  top: 19rpx;
  left: 17rpx;
}

.relationship-symbol-mutual .heart-one {
  top: 15rpx;
  left: 10rpx;
  transform: rotate(-45deg) scale(0.78);
}

.relationship-symbol-mutual .heart-two {
  top: 24rpx;
  left: 25rpx;
  transform: rotate(-45deg) scale(0.72);
}

.relationship-tab-copy,
.relationship-count,
.relationship-label,
.relationship-tab-note {
  display: block;
  min-width: 0;
}

.relationship-count {
  color: currentColor;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.relationship-label {
  margin-top: 8rpx;
  color: #241f1b;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
}

.relationship-tab-note {
  margin-top: 5rpx;
  overflow: hidden;
  color: #866b52;
  font-size: 19rpx;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relationship-panel {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(151, 119, 82, 0.14);
}

.relationship-panel-head {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.relationship-panel-title,
.relationship-panel-note {
  display: block;
}

.relationship-panel-title {
  color: #241f1b;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.relationship-panel-note {
  margin-top: 6rpx;
  color: #866b52;
  font-size: 21rpx;
  line-height: 1.4;
}

.relationship-panel-count {
  flex: 0 0 auto;
  color: #b4814f;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

.relationship-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.relationship-grid.single {
  grid-template-columns: minmax(0, 1fr);
}

.relationship-card {
  position: relative;
  box-sizing: border-box;
  min-width: 0;
  height: 282rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #4b3f37;
}

.relationship-grid.expanded .relationship-card {
  height: 304rpx;
}

.relationship-card:active {
  transform: scale(0.988);
}

.relationship-cover {
  display: block;
  width: 100%;
  height: 100%;
  background: #6f675f;
}

.relationship-cover-placeholder {
  background: linear-gradient(135deg, #946850, #315d66 54%, #b4814f);
}

.tone-1 .relationship-cover-placeholder {
  background: linear-gradient(135deg, #b18a42, #687d75 52%, #3b4c49);
}

.tone-2 .relationship-cover-placeholder {
  background: linear-gradient(135deg, #687d75, #574f52 52%, #a35b49);
}

.tone-3 .relationship-cover-placeholder {
  background: linear-gradient(135deg, #775b54, #315d66 48%, #c47a47);
}

.relationship-card.locked .relationship-cover {
  filter: blur(14rpx);
  transform: scale(1.08);
}

.relationship-cover-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(23, 20, 18, 0.06), rgba(23, 20, 18, 0.86));
}

.relationship-lock {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 2;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.9);
  color: #963b35;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
}

.relationship-card-copy {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  left: 16rpx;
  z-index: 2;
  min-width: 0;
  padding-right: 96rpx;
}

.relationship-card.locked .relationship-card-copy {
  padding-right: 0;
}

.relationship-hint,
.relationship-name,
.relationship-meta {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relationship-hint {
  display: inline-block;
  max-width: 100%;
  margin-bottom: 8rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 225, 0.9);
  color: #8b4a11;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1.2;
}

.relationship-name {
  color: #fffaf2;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.25;
}

.relationship-meta {
  margin-top: 5rpx;
  color: rgba(255, 250, 242, 0.88);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.35;
}

.relationship-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 10rpx;
  max-height: 48rpx;
  overflow: hidden;
}

.relationship-tag {
  box-sizing: border-box;
  max-width: 132rpx;
  padding: 5rpx 9rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fffaf2;
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relationship-card-action {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  z-index: 4;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  min-width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 50%;
  line-height: 1;
}

.relationship-card-action::after {
  border: 0;
}

.relationship-card-action.busy {
  opacity: 0.58;
}

.heart-action {
  background: #fffdf8;
  color: #963b35;
}

.heart-action .heart-shape {
  transform: rotate(-45deg) scale(0.72);
}

.chat-action {
  background: #fffdf8;
  color: #3e6758;
}

.heart-shape {
  position: relative;
  width: 25rpx;
  height: 23rpx;
  border-radius: 3rpx;
  background: currentColor;
  transform: rotate(-45deg);
}

.heart-shape::before,
.heart-shape::after {
  position: absolute;
  width: 25rpx;
  height: 25rpx;
  border-radius: 50%;
  background: currentColor;
  content: "";
}

.heart-shape::before {
  top: -13rpx;
  left: 0;
}

.heart-shape::after {
  top: 0;
  left: 13rpx;
}

.chat-shape {
  position: relative;
  box-sizing: border-box;
  width: 28rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.chat-shape::after {
  position: absolute;
  right: 2rpx;
  bottom: -7rpx;
  width: 8rpx;
  height: 8rpx;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  background: #fffdf8;
  content: "";
  transform: rotate(45deg);
}

.relationship-state {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 220rpx;
  padding: 28rpx 22rpx;
  border: 1rpx dashed rgba(177, 134, 83, 0.26);
  border-radius: 16rpx;
  background: rgba(244, 239, 231, 0.48);
}

.relationship-state.error {
  border-color: rgba(150, 59, 53, 0.24);
}

.relationship-state-title,
.relationship-state-note {
  display: block;
}

.relationship-state-title {
  color: #241f1b;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.relationship-state-note {
  margin-top: 8rpx;
  color: #866b52;
  font-size: 22rpx;
  line-height: 1.5;
}

.relationship-loading-mark {
  width: 34rpx;
  height: 34rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid rgba(177, 134, 83, 0.2);
  border-top-color: #b4814f;
  border-radius: 50%;
  animation: relationship-spin 800ms linear infinite;
}

@keyframes relationship-spin {
  to {
    transform: rotate(360deg);
  }
}

.relationship-retry {
  flex: 0 0 auto;
  width: 210rpx;
  margin-top: 18rpx;
}

.relationship-unlock {
  width: 100%;
  margin-top: 20rpx;
  background: #963b35;
  color: #fffaf2;
}

.relationship-footer-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.relationship-text-action {
  flex: 0 0 auto;
  width: auto;
  min-width: 150rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid rgba(177, 134, 83, 0.24);
  border-radius: 10rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #7b573a;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.relationship-text-action::after {
  border: 0;
}

.relationship-text-action.load-more {
  color: #3e6758;
}

.conversation-shell {
  padding: 22rpx;
}

.conversation-card {
  position: relative;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  min-height: 132rpx;
}

.conversation-avatar {
  width: 92rpx;
  height: 92rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.conversation-copy {
  min-width: 0;
}

.conversation-title-row {
  align-items: flex-start;
}

.conversation-title,
.conversation-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conversation-title {
  max-width: 360rpx;
}

.conversation-time {
  flex: 0 0 auto;
  color: #9b7b5d;
  font-size: 21rpx;
  line-height: 1.4;
}

.conversation-tags {
  margin-top: 10rpx;
}

.unread-badge {
  position: absolute;
  top: 22rpx;
  right: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #963b35;
  color: #fff8ed;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 32rpx;
  text-align: center;
}

.empty-action {
  margin-top: 22rpx;
}
