.messages-page {
  padding-top: 24rpx;
}

.messages-hero {
  min-height: 260rpx;
}

.conversation-shell {
  padding: 22rpx;
}

.notification-shell {
  padding: 22rpx;
}

.notification-card {
  position: relative;
  display: grid;
  grid-template-columns: 82rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  min-height: 118rpx;
}

.notification-avatar {
  width: 82rpx;
  height: 82rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.notification-copy {
  min-width: 0;
}

.notification-title-row {
  align-items: flex-start;
}

.notification-title,
.notification-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-title {
  max-width: 360rpx;
}

.notification-time {
  flex: 0 0 auto;
  color: #9b7b5d;
  font-size: 21rpx;
  line-height: 1.4;
}

.notification-tags {
  margin-top: 10rpx;
}

.notice-dot {
  position: absolute;
  top: 24rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #963b35;
  box-shadow: 0 0 0 4rpx rgba(150, 59, 53, 0.12);
}

.notification-empty {
  padding: 24rpx 8rpx 8rpx;
  color: #9b7b5d;
  font-size: 24rpx;
}

.conversation-card {
  position: relative;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: center;
  min-height: 132rpx;
}

.conversation-avatar {
  width: 92rpx;
  height: 92rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.conversation-copy {
  min-width: 0;
}

.conversation-title-row {
  align-items: flex-start;
}

.conversation-title,
.conversation-preview {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conversation-title {
  max-width: 360rpx;
}

.conversation-time {
  flex: 0 0 auto;
  color: #9b7b5d;
  font-size: 21rpx;
  line-height: 1.4;
}

.conversation-tags {
  margin-top: 10rpx;
}

.unread-badge {
  position: absolute;
  top: 22rpx;
  right: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #963b35;
  color: #fff8ed;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 32rpx;
  text-align: center;
}

.empty-action {
  margin-top: 22rpx;
}
