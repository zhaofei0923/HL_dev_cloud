.chat-page {
  min-height: 100vh;
  padding: 20rpx 20rpx 180rpx;
}

.chat-header {
  margin-bottom: 18rpx;
}

.chat-peer {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.94);
}

.chat-peer-avatar {
  width: 76rpx;
  height: 76rpx;
  border: 4rpx solid #fffdf8;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.chat-peer-copy {
  min-width: 0;
}

.chat-scroll {
  box-sizing: border-box;
  height: calc(100vh - 292rpx);
  padding: 8rpx 4rpx 40rpx;
}

.chat-empty {
  padding-top: 150rpx;
}

.message-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.message-stack {
  max-width: 74%;
}

.message-row.mine .message-stack {
  align-items: flex-end;
}

.message-time {
  display: block;
  margin-bottom: 8rpx;
  color: #9b7b5d;
  font-size: 20rpx;
  line-height: 1.3;
}

.message-row.mine .message-time {
  text-align: right;
}

.message-bubble {
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.15);
  border-radius: 16rpx;
  background: #fffdf8;
  color: #241f1b;
}

.message-row.mine .message-bubble {
  border-color: rgba(177, 134, 83, 0.32);
  background: #b4814f;
  color: #fff8ed;
}

.message-text {
  font-size: 27rpx;
  line-height: 1.55;
  word-break: break-word;
}

.chat-input-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(151, 119, 82, 0.14);
  background: rgba(245, 240, 232, 0.96);
}

.chat-input {
  box-sizing: border-box;
  flex: 1;
  min-height: 76rpx;
  max-height: 180rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.18);
  border-radius: 14rpx;
  background: #fffdf8;
  color: #241f1b;
  font-size: 27rpx;
  line-height: 1.45;
}

.send-button {
  flex: 0 0 132rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  background: #2b2420;
  color: #fff8ed;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 76rpx;
}

.send-button::after {
  border: 0;
}
