<view class="page with-bottom-nav messages-page">
  <view class="card hero messages-hero">
    <text class="eyebrow">消息</text>
    <text class="title">我的会话</text>
    <text class="subtitle">查看红娘服务沟通和已开通的配对沟通。</text>
    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{total}}</text>
        <text class="summary-label">会话</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">文字</text>
        <text class="summary-label">第一版</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">已读</text>
        <text class="summary-label">进入即处理</text>
      </view>
    </view>
  </view>

  <view class="card list-shell notification-shell">
    <view class="row list-header">
      <view>
        <text class="section-title">互动通知</text>
        <text class="section-note">{{loading ? '正在加载互动通知' : notificationUnreadCount ? notificationUnreadCount + ' 条未读' : '关注和系统提醒'}}</text>
      </view>
      <text class="tag gold">{{notificationTotal}} 条</text>
    </view>

    <block wx:if="{{notifications.length}}">
      <view wx:for="{{notifications}}" wx:key="id" class="list-card notification-card" data-id="{{item.id}}" bindtap="openNotification">
        <image class="notification-avatar" src="{{item.senderAvatar}}" mode="aspectFill"></image>
        <view class="notification-copy">
          <view class="row notification-title-row">
            <text class="item-title notification-title">{{item.senderName}}</text>
            <text class="notification-time">{{item.timeText}}</text>
          </view>
          <text class="item-meta notification-preview">{{item.preview}}</text>
          <view class="tag-row notification-tags">
            <text class="tag gold">{{item.typeText}}</text>
            <text class="tag">{{item.actionText}}</text>
          </view>
        </view>
        <text wx:if="{{item.hasUnread}}" class="notice-dot"></text>
      </view>
    </block>

    <view wx:else class="notification-empty">
      <text>{{loading ? '正在加载通知' : '暂无互动通知'}}</text>
    </view>
  </view>

  <view class="card list-shell conversation-shell">
    <view class="row list-header">
      <view>
        <text class="section-title">会话列表</text>
        <text class="section-note">{{loading ? '正在加载消息' : '按最新消息排序'}}</text>
      </view>
      <text class="tag gold">{{loading ? '刷新中' : total + ' 条'}}</text>
    </view>

    <block wx:if="{{list.length}}">
      <view wx:for="{{list}}" wx:key="id" class="list-card conversation-card" data-id="{{item.id}}" bindtap="openChat">
        <image class="conversation-avatar" src="{{item.peerAvatar}}" mode="aspectFill"></image>
        <view class="conversation-copy">
          <view class="row conversation-title-row">
            <text class="item-title conversation-title">{{item.peerName}}</text>
            <text class="conversation-time">{{item.timeText}}</text>
          </view>
          <text class="item-meta conversation-preview">{{item.preview}}</text>
          <view class="tag-row conversation-tags">
            <text class="tag gold">{{item.typeText}}</text>
          </view>
        </view>
        <text wx:if="{{item.hasUnread}}" class="unread-badge">{{item.unreadText}}</text>
      </view>
    </block>

    <view wx:else class="empty">
      <text class="empty-title">{{loading ? '正在加载消息' : emptyTitle}}</text>
      <text class="empty-note">{{loading ? '请稍候，正在整理你的会话。' : emptyNote}}</text>
      <button class="btn ghost empty-action" bindtap="goMembers">去看推荐</button>
    </view>
  </view>

  <bottom-nav role="user" active="messages"></bottom-nav>
</view>
