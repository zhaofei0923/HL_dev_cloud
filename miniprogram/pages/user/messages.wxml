<view class="page with-bottom-nav messages-page">
  <view class="card liked-me-shell">
    <view class="liked-me-header">
      <view class="liked-me-heading">
        <text class="eyebrow">谁喜欢我</text>
        <text class="title">{{likedMeTotal}} 人喜欢我</text>
        <text class="subtitle">{{isPremiumMember ? '查看对你有好感的会员资料。' : '开通会员后查看完整资料。'}}</text>
      </view>
      <text class="liked-me-status">{{isPremiumMember ? '已开通' : '待开通'}}</text>
    </view>

    <view wx:if="{{likedMeList.length}}" class="liked-me-grid">
      <view wx:for="{{likedMeList}}" wx:key="id" class="liked-card {{item.locked ? 'locked' : 'open'}} {{item.coverToneClass}}" data-id="{{item.id}}" bindtap="openLikedMember">
        <view class="liked-cover-wrap">
          <image wx:if="{{item.coverUrl}}" class="liked-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view wx:else class="liked-cover liked-cover-placeholder"></view>
          <view class="liked-cover-shade"></view>
          <text wx:if="{{item.locked}}" class="liked-lock">会员可见</text>
          <view class="liked-copy">
            <text class="liked-hint">{{item.hint}}</text>
            <text class="liked-name">{{item.displayName}}</text>
            <text class="liked-meta">{{item.metaText}}</text>
            <view class="liked-tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="liked-tag">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="liked-empty">
      <text class="liked-empty-title">{{loading ? '正在加载喜欢你的人' : '暂时还没有人喜欢你'}}</text>
      <text class="liked-empty-note">{{loading ? '请稍候，正在整理互动记录。' : '完善资料并多看看推荐会员，会提高被喜欢的机会。'}}</text>
    </view>

    <button wx:if="{{!isPremiumMember && likedMeTotal > 0}}" class="btn liked-unlock" bindtap="promptOpenMembership">开通会员查看全部</button>
  </view>

  <view class="card list-shell conversation-shell">
    <view class="row list-header">
      <view>
        <text class="section-title">会话列表</text>
        <text class="section-note">{{loading ? '正在加载消息' : '按最新消息排序'}}</text>
      </view>
      <text class="tag gold">{{loading ? '刷新中' : total + ' 条'}}</text>
    </view>

    <block wx:if="{{list.length}}">
      <view wx:for="{{list}}" wx:key="id" class="list-card conversation-card" data-id="{{item.id}}" bindtap="openChat">
        <image class="conversation-avatar" src="{{item.peerAvatar}}" mode="aspectFill"></image>
        <view class="conversation-copy">
          <view class="row conversation-title-row">
            <text class="item-title conversation-title">{{item.peerName}}</text>
            <text class="conversation-time">{{item.timeText}}</text>
          </view>
          <text class="item-meta conversation-preview">{{item.preview}}</text>
          <view class="tag-row conversation-tags">
            <text class="tag gold">{{item.typeText}}</text>
          </view>
        </view>
        <text wx:if="{{item.hasUnread}}" class="unread-badge">{{item.unreadText}}</text>
      </view>
    </block>

    <view wx:else class="empty">
      <text class="empty-title">{{loading ? '正在加载消息' : emptyTitle}}</text>
      <text class="empty-note">{{loading ? '请稍候，正在整理你的会话。' : emptyNote}}</text>
      <button class="btn ghost empty-action" bindtap="goMembers">去看推荐</button>
    </view>
  </view>

  <bottom-nav role="user" active="messages"></bottom-nav>
</view>
