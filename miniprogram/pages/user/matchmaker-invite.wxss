.invite-hero {
  min-height: 328rpx;
}

.invite-card {
  padding-bottom: 28rpx;
}

.invite-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.invite-avatar {
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(177, 134, 83, 0.12);
}

.invite-copy {
  flex: 1;
  min-width: 0;
}

.invite-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.notice-inline {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(177, 134, 83, 0.12);
}

.invite-action {
  margin-top: 18rpx;
}
