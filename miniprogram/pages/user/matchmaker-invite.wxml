<view class="page safe-bottom">
  <view class="card hero invite-hero">
    <text class="eyebrow">{{autoMode ? '会员注册' : '主理人邀请'}}</text>
    <text class="title">{{autoRegister ? '确认沙龙邀请' : (autoMode ? '注册成为会员' : '确认添加主理人')}}</text>
    <text class="subtitle">{{autoMode ? '通过微信分享链接进入后，系统会自动注册为该主理人名下免费会员。' : '通过扫码或手动邀请码进入，提交后仍需主理人审批，通过后才会成为该主理人名下会员。'}}</text>
    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{code || '待识别'}}</text>
        <text class="summary-label">邀请码</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{sourceText}}</text>
        <text class="summary-label">添加方式</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{autoMode ? '自动归属' : '审批'}}</text>
        <text class="summary-label">归属确认</text>
      </view>
    </view>
  </view>

  <view wx:if="{{errorText}}" class="card notice-card">
    <text class="section-title">邀请不可用</text>
    <text class="section-note">{{errorText}}</text>
    <button class="btn ghost invite-action" bindtap="goProfile">返回我的资料</button>
  </view>

  <view wx:elif="{{invite}}" class="card invite-card">
    <view class="invite-profile">
      <image class="invite-avatar" src="{{invite.avatarUrl || '/assets/members/avatar-female-1.png'}}" mode="aspectFill"></image>
      <view class="invite-copy">
        <text class="section-title">{{invite.nickname || '主理人'}}</text>
        <text class="section-note">主理人编号 {{invite.matchmakerNo}}</text>
      </view>
      <text class="tag gold">已认证</text>
    </view>

    <view class="invite-info-grid">
      <view class="metric">
        <text class="metric-label">会员服务</text>
        <text class="metric-value">{{invite.memberCount || 0}}</text>
        <text class="metric-hint">名下会员</text>
      </view>
      <view class="metric">
        <text class="metric-label">服务等级</text>
        <text class="metric-value">L{{invite.level || 1}}</text>
        <text class="metric-hint">主理人等级</text>
      </view>
    </view>

    <view wx:if="{{invite.alreadyAssigned}}" class="notice-inline">
      <text class="item-meta">{{autoMode ? '当前账号已有关联主理人，系统会继续确认是否为同一主理人。' : '你已有关联主理人，暂不能申请添加其他主理人。'}}</text>
    </view>
    <view wx:elif="{{!autoMode && invite.existingRequest && invite.existingRequest.status === 'pending'}}" class="notice-inline">
      <text class="item-meta">你已提交过申请，请等待主理人审批。</text>
    </view>
    <view wx:if="{{autoMessage}}" class="notice-inline {{autoDone ? 'success' : 'warning'}}">
      <text class="item-meta">{{autoMessage}}</text>
    </view>

    <button
      wx:if="{{autoMode}}"
      class="btn gold invite-action"
      loading="{{submitting}}"
      disabled="{{submitting || autoDone}}"
      bindtap="acceptShareInvite"
    >{{actionText}}</button>
    <button wx:else class="btn gold invite-action" loading="{{submitting}}" disabled="{{submitting || !canSubmit}}" bindtap="submitRequest">{{actionText}}</button>
    <button wx:if="{{autoMode && eventId}}" class="btn secondary invite-action" bindtap="goSalonDetail">查看沙龙详情</button>
    <button class="btn ghost invite-action" bindtap="copyCode">复制邀请码</button>
  </view>

  <view wx:else class="card invite-card">
    <text class="section-title">正在确认邀请</text>
    <text class="section-note">{{loading ? '正在读取主理人信息，请稍候。' : '请确认邀请码后重试。'}}</text>
  </view>
</view>
