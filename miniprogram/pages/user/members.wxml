<view class="page safe-bottom with-bottom-nav">
  <view class="card hero members-hero">
    <text class="eyebrow">隐私脱敏档案</text>
    <text class="title">优质会员</text>
    <text class="subtitle">浏览经红娘整理的公开档案，重点查看照片、城市、职业学历和择偶期待。</text>
    <view class="summary-strip">
      <view class="summary-item">
        <text class="summary-value">{{total}}</text>
        <text class="summary-label">可浏览</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">脱敏</text>
        <text class="summary-label">隐私展示</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">画像</text>
        <text class="summary-label">择偶期待</text>
      </view>
    </view>
  </view>

  <view class="card filter-card">
    <view class="row filter-head">
      <view>
        <text class="section-title">查找合适档案</text>
        <text class="section-note">按城市、性别和关键词快速缩小范围；联系方式和红娘备注始终不公开。</text>
      </view>
      <text class="tag gold">{{loading ? '整理中' : '隐私保护'}}</text>
    </view>
    <view class="field search-field">
      <input
        class="field-input"
        placeholder="输入城市 / 职业 / 学历"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onKeyword"
        bindconfirm="search"
      />
    </view>
    <view class="field compact-field">
      <input
        class="field-input"
        placeholder="单独筛选城市"
        value="{{city}}"
        confirm-type="search"
        bindinput="onCity"
        bindconfirm="search"
      />
    </view>
    <view class="quick-filter-row">
      <view class="quick-filter {{gender === '' ? 'active' : ''}}" data-gender="" bindtap="setGender">全部</view>
      <view class="quick-filter {{gender === '1' ? 'active' : ''}}" data-gender="1" bindtap="setGender">男士</view>
      <view class="quick-filter {{gender === '2' ? 'active' : ''}}" data-gender="2" bindtap="setGender">女士</view>
    </view>
    <view class="button-row">
      <button class="btn gold" loading="{{loading}}" disabled="{{loading}}" bindtap="search">搜索</button>
      <button class="btn secondary" disabled="{{loading}}" bindtap="clearKeyword">重置</button>
    </view>
  </view>

  <view class="card list-shell">
    <view class="row list-header">
      <view>
        <text class="section-title">公开档案</text>
        <text class="section-note">{{loading ? '正在整理会员资料' : countText}}</text>
      </view>
    </view>

    <block wx:if="{{list.length}}">
      <view wx:for="{{list}}" wx:key="id" class="list-card member-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="member-media">
          <image class="member-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <image class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        </view>
        <view class="row member-head">
          <view class="member-copy">
            <text class="item-title">{{item.displayName}}</text>
            <text class="item-meta">{{item.metaText}}</text>
            <text class="item-meta">{{item.workText}}</text>
          </view>
          <text class="tag gold">{{item.displayStatusText}}</text>
        </view>

        <view wx:if="{{item.highlightTags.length}}" class="tag-row">
          <text wx:for="{{item.highlightTags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
          <text class="tag rose">完整度 {{item.profileCompletionText}}</text>
        </view>

        <view class="member-section">
          <text class="member-label">择偶期待</text>
          <text class="item-desc">{{item.partnerText}}</text>
        </view>
        <text class="detail-link">查看完整档案</text>
      </view>
    </block>

    <view wx:else class="empty">
      <text class="empty-title">{{loading ? '正在加载会员' : emptyTitle}}</text>
      <text class="empty-note">{{loading ? '请稍候，正在整理可公开展示的会员档案。' : emptyNote}}</text>
    </view>
  </view>

  <view class="card notice-card privacy-card">
    <text class="section-title">想被更准确推荐？</text>
    <text class="section-note">完善自己的基础资料后，红娘可以基于城市、职业、价值观和活动偏好继续跟进。</text>
    <button class="btn ghost profile-btn" bindtap="goProfile">完善个人资料</button>
  </view>

  <bottom-nav role="user" active="members"></bottom-nav>
</view>
