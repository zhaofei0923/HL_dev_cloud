<view class="page recommend-page safe-bottom with-bottom-nav">
  <view class="recommend-topbar">
    <view class="recommend-heading">
      <text class="recommend-title">推荐</text>
      <text class="recommend-note">{{loading ? '正在整理会员资料' : countText}}</text>
    </view>
    <view class="topbar-actions">
      <button
        class="filter-trigger {{filterOpen ? 'active' : ''}}"
        aria-label="筛选"
        bindtap="toggleFilter"
      >
        <view class="filter-lines">
          <view class="filter-line line-top"></view>
          <view class="filter-line line-mid"></view>
          <view class="filter-line line-bottom"></view>
        </view>
      </button>
    </view>
  </view>

  <view wx:if="{{filterOpen}}" class="filter-panel">
    <view class="field search-field">
      <input
        class="field-input"
        placeholder="城市 / 职业 / 学历"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onKeyword"
        bindconfirm="search"
      />
    </view>
    <view class="field compact-field">
      <input
        class="field-input"
        placeholder="单独筛选城市"
        value="{{city}}"
        confirm-type="search"
        bindinput="onCity"
        bindconfirm="search"
      />
    </view>
    <view class="quick-filter-row">
      <view class="quick-filter {{gender === '' ? 'active' : ''}}" data-gender="" bindtap="setGender">全部</view>
      <view class="quick-filter {{gender === '1' ? 'active' : ''}}" data-gender="1" bindtap="setGender">男士</view>
      <view class="quick-filter {{gender === '2' ? 'active' : ''}}" data-gender="2" bindtap="setGender">女士</view>
    </view>
    <view class="button-row filter-buttons">
      <button class="btn gold" loading="{{loading}}" disabled="{{loading}}" bindtap="search">应用筛选</button>
      <button class="btn secondary" disabled="{{loading}}" bindtap="clearKeyword">重置</button>
    </view>
  </view>

  <view class="recommend-stage">
    <block wx:if="{{currentMember}}">
      <view
        class="recommend-card"
        bindtap="openCurrentDetail"
        bindtouchstart="onCardTouchStart"
        bindtouchend="onCardTouchEnd"
      >
        <image class="recommend-cover" src="{{currentMember.coverUrl}}" mode="aspectFill"></image>
        <view class="cover-shade"></view>
        <view class="card-top-meta">
          <text class="status-chip">{{currentMember.statusText}}</text>
          <text wx:if="{{positionText}}" class="position-chip">{{positionText}}</text>
        </view>
        <view class="member-overlay">
          <view class="privacy-chip">
            <view class="privacy-dot"></view>
            <text>公开资料已脱敏</text>
          </view>
          <view class="name-line">
            <text class="recommend-name">{{currentMember.displayName}}</text>
            <text class="recommend-age">{{currentMember.ageText}}</text>
          </view>
          <text class="recommend-meta">{{currentMember.primaryMeta}}</text>
          <text class="recommend-work">{{currentMember.profileLine}}</text>
          <view wx:if="{{currentMember.cardTags.length}}" class="card-tag-row">
            <text wx:for="{{currentMember.cardTags}}" wx:key="*this" class="card-tag">{{item}}</text>
          </view>
          <view class="quote-block">
            <text class="quote-mark">“</text>
            <text class="quote-text">{{currentMember.partnerPreview}}</text>
          </view>
        </view>
      </view>

      <view class="recommend-toolbar">
        <button class="toolbar-button toolbar-detail" catchtap="openCurrentDetail">查看详情</button>
        <button class="toolbar-button toolbar-next" catchtap="nextMember">换一位</button>
      </view>
    </block>

    <view wx:else class="recommend-empty">
      <text class="empty-title">{{loading ? '正在加载会员' : emptyTitle}}</text>
      <text class="empty-note">{{loading ? '请稍候，正在整理可公开展示的会员资料。' : emptyNote}}</text>
      <view class="button-row empty-buttons">
        <button class="btn gold" loading="{{loading}}" disabled="{{loading}}" bindtap="load">重新加载</button>
        <button class="btn ghost" bindtap="toggleFilter">调整筛选</button>
      </view>
      <button class="btn secondary profile-entry" bindtap="goProfile">完善我的资料</button>
    </view>
  </view>

  <bottom-nav role="user" active="members"></bottom-nav>
</view>
