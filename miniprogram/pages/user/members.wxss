.recommend-page {
  position: relative;
  padding-top: 18rpx;
  background:
    linear-gradient(180deg, rgba(36, 31, 27, 0.05) 0, rgba(245, 240, 232, 0) 280rpx),
    #f5f0e8;
}

.recommend-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  margin-bottom: 14rpx;
}

.recommend-heading {
  flex: 1;
  min-width: 0;
}

.recommend-title {
  display: block;
  color: #241f1b;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.recommend-note {
  display: block;
  max-width: 560rpx;
  margin-top: 6rpx;
  overflow: hidden;
  color: #7f6650;
  font-size: 22rpx;
  line-height: 1.36;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.filter-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(151, 119, 82, 0.18);
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #5d5149;
  font-size: 0;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(56, 42, 29, 0.08);
}

.filter-trigger::after,
.gift-close::after,
.gift-item::after {
  border: 0;
}

.filter-trigger.active {
  color: #7b573a;
  background: rgba(177, 134, 83, 0.14);
}

.filter-lines {
  position: relative;
  width: 40rpx;
  height: 34rpx;
}

.filter-line {
  position: absolute;
  left: 4rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.filter-line::after {
  position: absolute;
  top: -5rpx;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  background: #fffdf8;
  content: "";
}

.line-top {
  top: 2rpx;
  width: 32rpx;
}

.line-top::after {
  left: 18rpx;
}

.line-mid {
  top: 15rpx;
  width: 32rpx;
}

.line-mid::after {
  left: 4rpx;
}

.line-bottom {
  top: 28rpx;
  width: 32rpx;
}

.line-bottom::after {
  left: 21rpx;
}

.filter-panel {
  position: absolute;
  top: 126rpx;
  right: 24rpx;
  left: 24rpx;
  z-index: 30;
  box-sizing: border-box;
  padding: 22rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.18);
  border-radius: 16rpx;
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 18rpx 40rpx rgba(56, 42, 29, 0.12);
}

.filter-panel .field {
  margin-bottom: 14rpx;
}

.quick-filter-row {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 6rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 16rpx;
  padding: 6rpx;
  overflow: hidden;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 18rpx;
  background: rgba(248, 243, 235, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.quick-filter {
  box-sizing: border-box;
  display: flex;
  flex: 1 1 0;
  align-items: center;
  justify-content: center;
  width: 0;
  min-width: 0;
  height: 62rpx;
  margin: 0;
  padding: 0 6rpx;
  overflow: hidden;
  border: 0;
  border-radius: 14rpx;
  background: transparent;
  color: #736256;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.quick-filter.active {
  background: linear-gradient(180deg, #fffbf5 0%, #f1e5d7 100%);
  color: #7b573a;
  box-shadow: 0 6rpx 16rpx rgba(115, 83, 52, 0.12), inset 0 0 0 1rpx rgba(180, 129, 79, 0.26);
}

.filter-buttons {
  margin-top: 18rpx;
}

.filter-buttons .btn {
  height: 70rpx;
  font-size: 24rpx;
  line-height: 70rpx;
}

.recommend-stage {
  position: relative;
  min-height: calc(100vh - 214rpx);
}

.recommend-card {
  position: relative;
  height: calc(100vh - 344rpx);
  min-height: 780rpx;
  overflow: hidden;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 30rpx;
  background: #2b2420;
  box-shadow: 0 18rpx 42rpx rgba(56, 42, 29, 0.14);
}

.recommend-cover,
.cover-shade {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.recommend-cover {
  display: block;
}

.cover-shade {
  background:
    linear-gradient(180deg, rgba(36, 31, 27, 0.08) 0%, rgba(36, 31, 27, 0.02) 38%, rgba(36, 31, 27, 0.82) 100%),
    linear-gradient(90deg, rgba(36, 31, 27, 0.34), rgba(36, 31, 27, 0) 56%);
}

.card-top-meta {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  left: 24rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.status-chip,
.position-chip,
.privacy-chip {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #fff8ed;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
  background: rgba(36, 31, 27, 0.52);
  backdrop-filter: blur(14rpx);
}

.status-chip {
  background: rgba(177, 134, 83, 0.88);
}

.quick-actions {
  position: absolute;
  right: 28rpx;
  top: 50%;
  z-index: 4;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  transform: translateY(-36%);
}

.action-icon {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border: 2rpx solid rgba(255, 253, 248, 0.62);
  border-radius: 50%;
  color: #fff;
  font-size: 0;
  line-height: 1;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.24);
  backdrop-filter: blur(10rpx);
}

.action-icon-hover {
  opacity: 0.82;
  transform: scale(0.96);
}

.action-icon.disabled {
  opacity: 0.58;
}

.action-flyout {
  position: absolute;
  right: 28rpx;
  z-index: 7;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  pointer-events: none;
}

.action-flyout-gift {
  top: calc(50% - 124rpx);
  animation: flyout-gift 640ms ease-out forwards;
}

.action-flyout-heart {
  top: calc(50% - 32rpx);
  animation: flyout-heart 640ms ease-out forwards;
}

.action-flyout-hide {
  top: calc(50% + 60rpx);
  animation: flyout-hide 640ms ease-out forwards;
}

.flyout-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border: 2rpx solid rgba(255, 253, 248, 0.78);
  border-radius: 50%;
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.28);
}

.flyout-gift {
  background: #b4814f;
}

.flyout-heart {
  background: #e63b4f;
}

.flyout-hide {
  background: #558bbf;
  color: #fff;
}

@keyframes flyout-gift {
  0% {
    opacity: 0;
    transform: translate3d(0, 0, 0) scale(0.82) rotate(0);
  }
  18% {
    opacity: 1;
    transform: translate3d(-18rpx, -26rpx, 0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate3d(-210rpx, -252rpx, 0) scale(1.38) rotate(-14deg);
  }
}

@keyframes flyout-heart {
  0% {
    opacity: 0;
    transform: translate3d(0, 0, 0) scale(0.82);
  }
  18% {
    opacity: 1;
    transform: translate3d(-16rpx, -18rpx, 0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate3d(-214rpx, -214rpx, 0) scale(1.44);
  }
}

@keyframes flyout-hide {
  0% {
    opacity: 0;
    transform: translate3d(0, 0, 0) scale(0.82) rotate(0);
  }
  18% {
    opacity: 1;
    transform: translate3d(-16rpx, -10rpx, 0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate3d(-230rpx, -72rpx, 0) scale(1.34) rotate(20deg);
  }
}

.action-gift {
  background: rgba(180, 129, 79, 0.92);
}

.action-heart {
  background: rgba(180, 129, 79, 0.92);
}

.action-heart.active {
  border-color: rgba(255, 253, 248, 0.88);
  background: #e63b4f;
  box-shadow: 0 10rpx 24rpx rgba(230, 59, 79, 0.38);
}

.action-hide {
  background: rgba(85, 139, 191, 0.92);
}

.gift-shape {
  position: relative;
  width: 32rpx;
  height: 30rpx;
}

.gift-box {
  position: absolute;
  right: 2rpx;
  bottom: 0;
  left: 2rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: #fff;
}

.gift-box::before {
  position: absolute;
  top: 0;
  left: 13rpx;
  width: 5rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(180, 129, 79, 0.9);
  content: "";
}

.gift-bow {
  position: absolute;
  top: 0;
  left: 9rpx;
  width: 14rpx;
  height: 14rpx;
  transform: rotate(45deg);
}

.gift-bow::before,
.gift-bow::after {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #fff;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  content: "";
}

.gift-bow::before {
  top: -4rpx;
  left: -12rpx;
}

.gift-bow::after {
  top: -12rpx;
  left: -4rpx;
  transform: rotate(90deg);
}

.heart-shape {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  transform: rotate(-45deg);
  border-radius: 6rpx;
  background: #fff;
}

.heart-shape::before,
.heart-shape::after {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #fff;
  content: "";
}

.heart-shape::before {
  top: -14rpx;
  left: 0;
}

.heart-shape::after {
  top: 0;
  left: 14rpx;
}

.x-shape {
  position: relative;
  width: 30rpx;
  height: 30rpx;
}

.x-shape.small {
  width: 34rpx;
  height: 34rpx;
}

.x-line {
  position: absolute;
  top: 13rpx;
  left: 0;
  width: 30rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.x-shape.small .x-line {
  top: 15rpx;
  width: 34rpx;
  height: 5rpx;
}

.x-left {
  transform: rotate(45deg);
}

.x-right {
  transform: rotate(-45deg);
}

.member-overlay {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 2;
  box-sizing: border-box;
  padding: 0 118rpx 38rpx 32rpx;
}

.privacy-chip {
  display: inline-flex;
  max-width: 100%;
  margin-bottom: 22rpx;
  color: #fffdf8;
}

.privacy-dot {
  width: 13rpx;
  height: 13rpx;
  margin-right: 10rpx;
  border: 3rpx solid rgba(255, 253, 248, 0.92);
  border-radius: 50%;
  background: #5fa46f;
}

.name-line {
  display: flex;
  align-items: baseline;
  gap: 22rpx;
  max-width: 100%;
}

.recommend-name,
.recommend-age,
.recommend-meta,
.recommend-work,
.quote-text {
  display: block;
  color: #fffdf8;
  text-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.32);
}

.recommend-name {
  max-width: 360rpx;
  overflow: hidden;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-age {
  flex: 0 0 auto;
  font-size: 35rpx;
  font-weight: 800;
  line-height: 1.18;
}

.recommend-meta,
.recommend-work {
  max-width: 100%;
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-meta {
  margin-top: 18rpx;
}

.recommend-work {
  margin-top: 4rpx;
  color: rgba(255, 248, 237, 0.84);
}

.card-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  max-height: 94rpx;
  margin-top: 18rpx;
  overflow: hidden;
}

.card-tag {
  box-sizing: border-box;
  max-width: 100%;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  color: #6e4d35;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
  background: rgba(255, 253, 248, 0.9);
}

.quote-block {
  display: flex;
  gap: 6rpx;
  margin-top: 20rpx;
}

.quote-mark {
  flex: 0 0 auto;
  color: #e8c79a;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.1;
}

.quote-text {
  flex: 1;
  min-width: 0;
  color: rgba(255, 248, 237, 0.94);
  font-size: 25rpx;
  line-height: 1.48;
}

.member-detail-stack {
  margin-top: 20rpx;
}

.detail-panel {
  box-sizing: border-box;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 253, 248, 0.97);
  box-shadow: 0 10rpx 24rpx rgba(56, 42, 29, 0.06);
}

.detail-panel:last-child {
  margin-bottom: 0;
}

.detail-header {
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.photo-strip {
  width: 100%;
  white-space: nowrap;
}

.inline-photo {
  display: inline-block;
  width: 238rpx;
  height: 310rpx;
  margin-right: 14rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #17130f;
}

.inline-photo:last-child {
  margin-right: 0;
}

.inline-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.inline-info-cell {
  box-sizing: border-box;
  min-height: 118rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.13);
  border-radius: 14rpx;
  background: rgba(248, 243, 235, 0.72);
}

.detail-tags {
  margin-top: 18rpx;
}

.story-panel .section-title + .item-desc {
  margin-top: 12rpx;
}

.recommend-empty {
  box-sizing: border-box;
  min-height: 760rpx;
  padding: 160rpx 28rpx 40rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 253, 248, 0.94);
  text-align: center;
  box-shadow: 0 14rpx 34rpx rgba(56, 42, 29, 0.08);
}

.empty-buttons {
  margin-top: 28rpx;
}

.profile-entry {
  margin-top: 16rpx;
}

.gift-mask {
  position: fixed;
  inset: 0;
  z-index: 120;
  background: rgba(36, 31, 27, 0.38);
}

.gift-panel {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 130;
  box-sizing: border-box;
  padding: 30rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdf8;
  box-shadow: 0 -20rpx 46rpx rgba(36, 31, 27, 0.18);
}

.gift-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.gift-panel-title,
.gift-panel-subtitle,
.gift-name,
.gift-description,
.gift-loading {
  display: block;
}

.gift-panel-title {
  color: #241f1b;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.28;
}

.gift-panel-subtitle {
  margin-top: 6rpx;
  color: #7f6650;
  font-size: 23rpx;
  line-height: 1.38;
}

.gift-close {
  flex: 0 0 64rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border: 2rpx solid rgba(151, 119, 82, 0.18);
  border-radius: 50%;
  background: rgba(248, 243, 235, 0.9);
  color: #6e4d35;
  font-size: 0;
  line-height: 1;
}

.gift-close-hover {
  opacity: 0.78;
  transform: scale(0.96);
}

.gift-close.disabled {
  opacity: 0.45;
}

.gift-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.gift-item {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 116rpx;
  margin: 0;
  padding: 18rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.15);
  border-radius: 16rpx;
  background: rgba(248, 243, 235, 0.72);
  text-align: left;
}

.gift-item[disabled] {
  opacity: 0.68;
}

.gift-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  color: #fffdf8;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.gift-rose {
  background: #d92746;
}

.gift-coffee {
  background: #8a6242;
}

.gift-star {
  background: #6a58d8;
}

.gift-sweet {
  background: #cc7a31;
}

.gift-copy {
  flex: 1;
  min-width: 0;
}

.gift-name {
  overflow: hidden;
  color: #241f1b;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.32;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gift-description {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: #7f6650;
  font-size: 21rpx;
  line-height: 1.34;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.gift-loading {
  grid-column: 1 / -1;
  padding: 32rpx 0;
  color: #7f6650;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}
