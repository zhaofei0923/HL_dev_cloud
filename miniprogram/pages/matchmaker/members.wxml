<view class="page safe-bottom {{canOperate ? 'with-bottom-nav' : ''}}">
  <block wx:if="{{canOperate}}">
    <view class="card hero members-hero">
      <text class="eyebrow">会员经营</text>
      <text class="title">会员经营</text>
      <text class="subtitle">录入、筛选和维护名下会员，沉淀可展示、可互推的服务资源。</text>
      <view class="summary-strip">
        <view class="summary-item">
          <text class="summary-value">{{total}}</text>
          <text class="summary-label">名下会员</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">资源池</text>
          <text class="summary-label">可互推</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">录入</text>
          <text class="summary-label">持续维护</text>
        </view>
      </view>
    </view>

    <view wx:if="{{pendingRequests.length}}" class="card request-card">
      <view class="row request-head">
        <view>
          <text class="section-title">待审批会员申请</text>
          <text class="section-note">{{pendingRequests.length}} 位会员申请添加你为红娘。</text>
        </view>
        <text class="tag gold">待处理</text>
      </view>
      <view wx:for="{{pendingRequests}}" wx:key="id" class="request-item">
        <view class="request-copy">
          <text class="item-title">{{item.displayName}}</text>
          <text class="item-meta">{{item.metaText}}</text>
          <text class="item-desc">{{item.noteText}}</text>
        </view>
        <view class="request-actions">
          <button class="btn gold small-btn" data-id="{{item.id}}" loading="{{requestProcessingId === item.idText}}" disabled="{{requestProcessingId === item.idText}}" catchtap="approveRequest">通过</button>
          <button class="btn danger small-btn" data-id="{{item.id}}" disabled="{{requestProcessingId === item.idText}}" catchtap="rejectRequest">拒绝</button>
        </view>
      </view>
    </view>

    <view class="card search-card">
      <view class="row search-head">
        <view>
          <text class="section-title">查找会员</text>
          <text class="section-note">按姓名、城市、性别、会员类型和服务等级筛选。</text>
        </view>
        <text class="tag gold">{{loading ? '加载中' : '已整理'}}</text>
      </view>
      <view class="field search-field">
        <text class="field-label">关键词</text>
        <input class="field-input" value="{{keyword}}" bindinput="onKeyword" confirm-type="search" bindconfirm="load" placeholder="输入姓名 / 城市 / 职业" />
      </view>
      <view class="field search-field compact-field">
        <text class="field-label">城市</text>
        <input class="field-input" value="{{city}}" bindinput="onCity" confirm-type="search" bindconfirm="load" placeholder="输入城市" />
      </view>
      <view class="quick-filter-row">
        <view class="quick-filter {{gender === '' ? 'active' : ''}}" data-gender="" bindtap="setGender">全部</view>
        <view class="quick-filter {{gender === '1' ? 'active' : ''}}" data-gender="1" bindtap="setGender">男士</view>
        <view class="quick-filter {{gender === '2' ? 'active' : ''}}" data-gender="2" bindtap="setGender">女士</view>
      </view>
      <view class="filter-grid">
        <picker mode="selector" range="{{memberTypeOptions}}" bindchange="onMemberTypeChange">
          <view class="field picker-field">
            <text class="field-label">会员类型</text>
            <text class="field-input picker-value">{{memberTypeLabel}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{serviceLevelOptions}}" bindchange="onServiceLevelChange">
          <view class="field picker-field">
            <text class="field-label">服务等级</text>
            <text class="field-input picker-value">{{serviceLevelLabel}}</text>
          </view>
        </picker>
      </view>
      <view class="button-row">
        <button class="btn gold" loading="{{loading}}" disabled="{{loading}}" bindtap="load">搜索</button>
        <button class="btn secondary" disabled="{{loading}}" bindtap="clearFilters">重置筛选</button>
        <button class="btn secondary" bindtap="goAdd">录入会员</button>
      </view>
      <button class="btn ghost resource-link" bindtap="goResources">进入会员展示资源池</button>
    </view>

    <view class="card list-shell">
      <view class="row list-header">
        <view>
          <text class="section-title">会员列表</text>
          <text class="section-note">{{total}} 位会员</text>
        </view>
      </view>

      <block wx:if="{{list.length}}">
        <view wx:for="{{list}}" wx:key="id" class="list-card member-card" data-id="{{item.id}}" bindtap="openDetail">
          <view class="member-media">
            <image class="member-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
            <image class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          </view>
          <view class="row member-head">
            <view class="member-copy">
              <text class="item-title">{{item.displayName}}</text>
              <text class="item-meta">{{item.metaText}}</text>
              <text class="item-meta">{{item.occupationText}}</text>
            </view>
            <text class="tag gold">{{item.memberTypeText}}</text>
          </view>
          <view class="tag-row">
            <text class="tag">{{item.city || '城市待确认'}}</text>
            <text class="tag rose">{{item.incomeText}}</text>
            <text class="tag gold">{{item.displayStatusText}}</text>
          </view>
          <view class="member-status-row">
            <text class="status-pill">完整度 {{item.profileCompletionText}}</text>
            <text class="status-pill">推荐 {{item.lastRecommendStatusText}}</text>
            <text class="status-pill">{{item.serviceLevelText}}</text>
          </view>
          <view class="card-action-row">
            <text class="detail-link">查看完整档案</text>
            <button class="btn danger remove-btn" data-id="{{item.id}}" loading="{{removingId === item.id}}" disabled="{{removingId === item.id}}" catchtap="remove">移除会员</button>
          </view>
        </view>
      </block>

      <view wx:else class="empty">
        <text class="empty-title">{{loading ? '正在加载会员' : '暂无会员'}}</text>
        <text class="empty-note">{{loading ? '请稍候，正在整理会员列表。' : '先录入一位会员，再进入资源展示和互推流程。'}}</text>
      </view>
    </view>
  </block>

  <view wx:else class="card approval-card">
    <view class="row approval-head">
      <view>
        <text class="section-title">会员经营待开通</text>
        <text class="section-note">{{statusNote}}</text>
      </view>
      <text class="tag {{statusTagClass}}">{{statusText}}</text>
    </view>
    <button wx:if="{{statusText === '已拒绝'}}" class="btn gold approval-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="applyAgain">重新提交申请</button>
  </view>
  <bottom-nav wx:if="{{canOperate}}" role="matchmaker" active="members"></bottom-nav>
</view>
