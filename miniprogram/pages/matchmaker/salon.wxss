.salon-ops-hero {
  min-height: 310rpx;
}

.action-head,
.ops-head {
  align-items: flex-start;
}

.approval-head {
  align-items: flex-start;
}

.approval-btn {
  margin-top: 22rpx;
}

.create-btn {
  margin-top: 20rpx;
}

.invite-picker {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 12rpx;
  background: #fffdf8;
}

.invite-picker .picker-value {
  display: block;
  color: #241f1b;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.4;
}

.ops-copy {
  flex: 1;
  min-width: 0;
  margin-right: 14rpx;
}

.invite-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.invite-btn {
  height: 70rpx;
  font-size: 24rpx;
  line-height: 70rpx;
}

.review-note {
  display: block;
  margin-top: 18rpx;
  padding: 14rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(177, 134, 83, 0.1);
  color: #74513a;
  font-size: 23rpx;
  line-height: 1.45;
}

.cancel-btn {
  margin-top: 18rpx;
}
