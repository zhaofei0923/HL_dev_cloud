.dashboard-hero {
  min-height: 312rpx;
}

.approval-hero {
  min-height: 328rpx;
}

.dashboard-grid {
  margin-top: 22rpx;
}

.task-list {
  margin-top: 20rpx;
}

.approval-head {
  align-items: flex-start;
}

.approval-btn {
  margin-top: 22rpx;
}

.approval-flow {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.flow-item {
  min-width: 0;
  padding: 18rpx 10rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.72);
  text-align: center;
}

.flow-item.active {
  border-color: rgba(180, 129, 79, 0.34);
  background: rgba(180, 129, 79, 0.12);
}

.flow-dot,
.flow-copy {
  display: block;
}

.flow-dot {
  width: 38rpx;
  height: 38rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  background: rgba(36, 31, 27, 0.08);
  color: #7b573a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.flow-item.active .flow-dot {
  background: #b4814f;
  color: #fffdf8;
}

.flow-copy {
  color: #736256;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.task-btn {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  min-height: 108rpx;
  margin: 0 0 14rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.15);
  border-radius: 14rpx;
  background: #fffdf8;
  color: #241f1b;
  line-height: 1.4;
  text-align: left;
}

.task-btn:last-child {
  margin-bottom: 0;
}

.task-btn::after {
  border: 0;
}

.task-title,
.task-note {
  display: block;
}

.task-title {
  font-size: 29rpx;
  font-weight: 800;
}

.task-badge {
  position: absolute;
  top: 20rpx;
  right: 22rpx;
  min-width: 48rpx;
  height: 44rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(180, 129, 79, 0.14);
  color: #7b573a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 44rpx;
  text-align: center;
}

.task-note {
  margin-top: 8rpx;
  padding-right: 72rpx;
  color: #736256;
  font-size: 23rpx;
}
