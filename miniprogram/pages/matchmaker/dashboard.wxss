.dashboard-hero {
  min-height: 312rpx;
}

.approval-hero {
  min-height: 328rpx;
}

.dashboard-grid {
  margin-top: 22rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
  width: 100%;
  margin-top: 20rpx;
}

.approval-head {
  align-items: flex-start;
}

.approval-btn {
  margin-top: 22rpx;
}

.approval-flow {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.flow-item {
  min-width: 0;
  padding: 18rpx 10rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.72);
  text-align: center;
}

.flow-item.active {
  border-color: rgba(180, 129, 79, 0.34);
  background: rgba(180, 129, 79, 0.12);
}

.flow-dot,
.flow-copy {
  display: block;
}

.flow-dot {
  width: 38rpx;
  height: 38rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  background: rgba(36, 31, 27, 0.08);
  color: #7b573a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.flow-item.active .flow-dot {
  background: #b4814f;
  color: #fffdf8;
}

.flow-copy {
  color: #736256;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.task-btn {
  position: relative;
  box-sizing: border-box;
  display: block;
  align-self: stretch;
  flex: 0 0 auto;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 124rpx;
  margin: 0;
  padding: 24rpx 122rpx 22rpx 24rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.15);
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #fbf7f0 100%);
  color: #241f1b;
  line-height: 1.4;
  text-align: left;
  box-shadow: 0 8rpx 22rpx rgba(36, 31, 27, 0.04);
}

.task-title,
.task-note {
  display: block;
}

.task-title {
  padding-right: 0;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.25;
  word-break: break-all;
}

.task-badge {
  position: absolute;
  top: 50%;
  right: 24rpx;
  min-width: 56rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(180, 129, 79, 0.14);
  color: #7b573a;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 44rpx;
  text-align: center;
  transform: translateY(-50%);
}

.task-note {
  margin-top: 8rpx;
  color: #736256;
  font-size: 23rpx;
  line-height: 1.34;
  word-break: break-all;
}
