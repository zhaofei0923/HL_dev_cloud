.members-hero {
  min-height: 310rpx;
}

.search-head,
.member-head {
  align-items: flex-start;
}

.request-head {
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.request-item {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(151, 119, 82, 0.12);
}

.request-copy {
  min-width: 0;
}

.request-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.recommend-head {
  align-items: flex-start;
}

.recommend-select-grid,
.recommend-pair {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.recommend-picker {
  margin: 0;
}

.recommend-person {
  box-sizing: border-box;
  min-width: 0;
  min-height: 196rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 14rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #fbf7f0 100%);
}

.recommend-person.empty {
  background: rgba(115, 98, 86, 0.06);
}

.recommend-name,
.recommend-meta {
  display: block;
}

.recommend-name {
  color: #241f1b;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.3;
}

.recommend-meta {
  margin-top: 8rpx;
  color: #736256;
  font-size: 22rpx;
  line-height: 1.42;
}

.recommend-tags {
  margin-top: 14rpx;
}

.recommend-hint {
  display: block;
  margin-top: 18rpx;
  color: #7f6650;
  font-size: 23rpx;
  line-height: 1.45;
}

.internal-recommend-btn {
  margin-top: 18rpx;
}

.small-btn {
  height: 66rpx;
  font-size: 24rpx;
  line-height: 66rpx;
}

.search-field {
  margin-top: 20rpx;
}

.compact-field {
  margin-top: 14rpx;
}

.quick-filter-row {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 6rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 16rpx;
  padding: 6rpx;
  overflow: hidden;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 18rpx;
  background: rgba(248, 243, 235, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.quick-filter {
  box-sizing: border-box;
  display: flex;
  flex: 1 1 0;
  align-items: center;
  justify-content: center;
  width: 0;
  min-width: 0;
  height: 64rpx;
  margin: 0;
  padding: 0 6rpx;
  overflow: hidden;
  border: 0;
  border-radius: 14rpx;
  background: transparent;
  color: #736256;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.quick-filter.active {
  background: linear-gradient(180deg, #fffbf5 0%, #f1e5d7 100%);
  color: #7b573a;
  box-shadow: 0 6rpx 16rpx rgba(115, 83, 52, 0.12), inset 0 0 0 1rpx rgba(180, 129, 79, 0.26);
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.picker-field {
  margin: 0;
}

.picker-value {
  display: block;
  line-height: 1.45;
}

.resource-link {
  margin-top: 14rpx;
}

.member-copy {
  flex: 1;
  min-width: 0;
  margin-right: 14rpx;
}

.member-media {
  position: relative;
  height: 238rpx;
  margin: -6rpx -6rpx 24rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: rgba(177, 134, 83, 0.12);
}

.member-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.member-avatar {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  width: 104rpx;
  height: 104rpx;
  border: 5rpx solid #fffdf8;
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx rgba(36, 31, 27, 0.18);
}

.card-action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.member-status-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.status-pill {
  min-width: 0;
  padding: 12rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(177, 134, 83, 0.1);
  color: #74513a;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
}

.detail-link {
  flex: 1;
  min-width: 0;
  color: #b4814f;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.4;
}

.remove-btn {
  flex: 0 0 190rpx;
  height: 68rpx;
  font-size: 24rpx;
  line-height: 68rpx;
}
