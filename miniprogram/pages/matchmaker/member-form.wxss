.member-form-hero {
  min-height: 278rpx;
}

.field-row {
  display: flex;
  gap: 14rpx;
}

.field.half {
  flex: 1;
  min-width: 0;
}

.picker-value {
  display: flex;
  align-items: center;
}

.image-upload-panel {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.14);
  border-radius: 14rpx;
  background: rgba(255, 253, 248, 0.72);
}

.upload-avatar {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.upload-copy {
  flex: 1;
  min-width: 0;
}

.upload-btn {
  width: 190rpx;
  height: 64rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.photo-thumb {
  width: 100%;
  height: 142rpx;
  border-radius: 12rpx;
  background: rgba(177, 134, 83, 0.12);
}

.upload-wall-btn {
  margin-top: 14rpx;
}

.save-btn {
  margin-top: 24rpx;
}
