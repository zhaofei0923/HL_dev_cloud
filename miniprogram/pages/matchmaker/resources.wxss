.resources-hero {
  min-height: 310rpx;
}

.access-card .row,
.resource-head {
  align-items: flex-start;
}

.selected-member {
  display: block;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: rgba(177, 134, 83, 0.12);
  color: #6e4d35;
  font-size: 23rpx;
  line-height: 1.45;
}

.selected-member.muted {
  background: rgba(115, 98, 86, 0.08);
  color: #736256;
}

.member-picker {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 12rpx;
  background: #fffdf8;
}

.member-picker .picker-value {
  display: block;
  color: #241f1b;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.4;
}

.resource-copy {
  flex: 1;
  min-width: 0;
  margin-right: 14rpx;
}

.resource-media {
  position: relative;
  height: 226rpx;
  margin: -6rpx -6rpx 24rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: rgba(177, 134, 83, 0.12);
}

.resource-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.resource-avatar {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  width: 100rpx;
  height: 100rpx;
  border: 5rpx solid #fffdf8;
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx rgba(36, 31, 27, 0.18);
}

.detail-btn {
  margin-top: 18rpx;
}

.recommend-btn {
  margin-top: 14rpx;
}
