.bottom-nav-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 90;
  box-sizing: border-box;
  width: 100%;
  padding: 10rpx 22rpx calc(10rpx + env(safe-area-inset-bottom));
  background: rgba(245, 240, 232, 0.9);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 -12rpx 28rpx rgba(56, 42, 29, 0.08);
}

.bottom-nav {
  box-sizing: border-box;
  display: flex;
  width: 100%;
  min-height: 96rpx;
  border: 1rpx solid rgba(151, 119, 82, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 253, 248, 0.98);
  overflow: hidden;
}

.bottom-nav-admin {
  display: flex;
}

.bottom-nav-matchmaker {
  display: flex;
}

.bottom-nav-item {
  box-sizing: border-box;
  display: flex;
  flex: 1 1 0;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 0;
  min-width: 0;
  height: 96rpx;
  margin: 0;
  padding: 8rpx 4rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #2b2420;
  line-height: 1;
}

.bottom-nav-item::after {
  border: 0;
}

.bottom-nav-hover {
  background: rgba(177, 134, 83, 0.08);
}

.bottom-nav-item.active {
  color: #b4814f;
  background: rgba(177, 134, 83, 0.1);
}

.bottom-nav-label {
  display: block;
  max-width: 100%;
  color: currentColor;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.22;
  white-space: nowrap;
}

.nav-icon {
  position: relative;
  width: 42rpx;
  height: 38rpx;
  color: currentColor;
}

.nav-icon-mark,
.nav-icon-mark::before,
.nav-icon-mark::after {
  position: absolute;
  box-sizing: border-box;
  content: "";
}

.nav-icon-members .nav-icon-mark {
  top: 5rpx;
  left: 8rpx;
  width: 15rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.nav-icon-members .nav-icon-mark::before {
  top: 4rpx;
  left: 18rpx;
  width: 13rpx;
  height: 13rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.nav-icon-members .nav-icon-mark::after {
  top: 21rpx;
  left: -5rpx;
  width: 40rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
}

.nav-icon-salon .nav-icon-mark {
  top: 7rpx;
  left: 6rpx;
  width: 32rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.nav-icon-salon .nav-icon-mark::before {
  top: 8rpx;
  left: -4rpx;
  width: 32rpx;
  height: 4rpx;
  background: currentColor;
}

.nav-icon-salon .nav-icon-mark::after {
  top: -8rpx;
  left: 6rpx;
  width: 4rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 13rpx 0 0 currentColor;
}

.nav-icon-mine .nav-icon-mark {
  top: 4rpx;
  left: 14rpx;
  width: 17rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.nav-icon-mine .nav-icon-mark::after {
  top: 23rpx;
  left: -10rpx;
  width: 38rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-radius: 20rpx 20rpx 8rpx 8rpx;
}

.nav-icon-dashboard .nav-icon-mark {
  top: 7rpx;
  left: 7rpx;
  width: 13rpx;
  height: 13rpx;
  border-radius: 4rpx;
  background: currentColor;
  box-shadow: 17rpx 0 0 currentColor, 0 17rpx 0 currentColor, 17rpx 17rpx 0 currentColor;
}
